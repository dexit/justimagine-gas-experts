# Copy this file to .env.local and fill in your values.
# All VITE_* variables are replaced at build time and bundled into the client code —
# do NOT put secrets here. These are all public tracking IDs.

# ── Google Tag Manager ──────────────────────────────────────────────────────
# Recommended: manages GA4, Google Ads, and other tags from one place.
# Find in GTM dashboard → Admin → Container ID (format: GTM-XXXXXXX)
VITE_GTM_ID=

# ── Google Analytics 4 ──────────────────────────────────────────────────────
# Only set this if you are NOT loading GA4 through GTM (to avoid double-counting).
# Find in GA4 → Admin → Data Streams → Measurement ID (format: G-XXXXXXXXXX)
VITE_GA4_ID=

# ── Microsoft Clarity ───────────────────────────────────────────────────────
# Heatmaps and session recordings. Free at clarity.microsoft.com
# Find in Clarity → Settings → Overview → Project ID (format: xxxxxxxxxx)
VITE_CLARITY_ID=

# ── HubSpot ─────────────────────────────────────────────────────────────────
# CRM contact tracking. Set either HUBSPOT_ID or BREVO_ID, not both.
# Find in HubSpot → Settings → Tracking Code → Hub ID (format: 12345678)
VITE_HUBSPOT_ID=

# ── Brevo (Sendinblue) ──────────────────────────────────────────────────────
# Conversations chat widget (alternative to HubSpot).
# Find in Brevo → Conversations → Settings → Widget ID
VITE_BREVO_ID=

# ── IndexNow ────────────────────────────────────────────────────────────────
# Instant indexing for Bing, Yandex, and others.
# Generate a key at https://www.indexnow.org/documentation — must match public/indexnow-key.txt
VITE_INDEXNOW_KEY=

# ── Bing Webmaster Tools ────────────────────────────────────────────────────
# Site verification for Bing Search Console.
# Find in Bing Webmaster Tools → Settings → Site Verification → Meta tag content value
VITE_BING_VERIFY=

# ── Google Search Console ───────────────────────────────────────────────────
# Site ownership verification.
# Find in Google Search Console → Settings → Ownership verification → HTML tag content value
VITE_GOOGLE_VERIFY=

# ── Storage Backend Configuration ───────────────────────────────────────────
# Choose primary backend: vercel (recommended), cloudflare, or hybrid

# Vercel KV (Redis) - Admin sessions, leads, analytics cache, rate limiting
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Blob - Service images, portfolio uploads
BLOB_READ_WRITE_TOKEN=

# Cloudflare D1 (SQLite) - Alternative persistent database for CMS data
D1_DATABASE_ID=
D1_API_TOKEN=
D1_ENDPOINT=

# Cloudflare KV - Alternative session store
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=

# Cloudflare R2 - Alternative object storage
R2_BUCKET_NAME=
R2_ACCOUNT_ID=

# ── Admin Panel ─────────────────────────────────────────────────────────────
# Credentials for /admin dashboard access
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ── Analytics APIs (for real data pulling into admin dashboard) ──────────────
# GA4 - Traffic, users, conversions
GA4_ACCESS_TOKEN=
GA4_PROPERTY_ID=

# Google Search Console - Search clicks, impressions, keywords
GSC_REFRESH_TOKEN=
GSC_SITE_URL=https://justimagine.ltd

# Microsoft Clarity - Session recordings, heatmaps (real dashboard data)
CLARITY_PROJECT_ID=
CLARITY_API_KEY=

# Bing Webmaster Tools - Alternative search analytics
BING_WEBMASTER_API_KEY=

# ── Environment & Feature Flags ─────────────────────────────────────────────
STORAGE_BACKEND=vercel
ENVIRONMENT=production
LOG_LEVEL=info
PERSIST_CMS=true
TRACK_ANALYTICS=true
OBSERVABILITY=true
RATE_LIMIT=true

# ── Vercel Project Info ─────────────────────────────────────────────────────
VERCEL_PROJECT_ID=
VERCEL_ENV=production
VERCEL_URL=

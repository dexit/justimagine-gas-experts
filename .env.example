# Copy this file to .env.local and fill in your values.
# All VITE_* variables are replaced at build time and bundled into the client code —
# do NOT put secrets here. These are all public tracking IDs.

# ── Google Tag Manager ──────────────────────────────────────────────────────
# Recommended: manages GA4, Google Ads, and other tags from one place.
# Find in GTM dashboard → Admin → Container ID (format: GTM-XXXXXXX)
VITE_GTM_ID=

# ── Google Analytics 4 ──────────────────────────────────────────────────────
# Only set this if you are NOT loading GA4 through GTM (to avoid double-counting).
# Find in GA4 → Admin → Data Streams → Measurement ID (format: G-XXXXXXXXXX)
VITE_GA4_ID=

# ── Microsoft Clarity ───────────────────────────────────────────────────────
# Heatmaps and session recordings. Free at clarity.microsoft.com
# Find in Clarity → Settings → Overview → Project ID (format: xxxxxxxxxx)
VITE_CLARITY_ID=

# ── HubSpot ─────────────────────────────────────────────────────────────────
# CRM contact tracking. Set either HUBSPOT_ID or BREVO_ID, not both.
# Find in HubSpot → Settings → Tracking Code → Hub ID (format: 12345678)
VITE_HUBSPOT_ID=

# ── Brevo (Sendinblue) ──────────────────────────────────────────────────────
# Conversations chat widget (alternative to HubSpot).
# Find in Brevo → Conversations → Settings → Widget ID
VITE_BREVO_ID=

# ── IndexNow ────────────────────────────────────────────────────────────────
# Instant indexing for Bing, Yandex, and others.
# Generate a key at https://www.indexnow.org/documentation — must match public/indexnow-key.txt
VITE_INDEXNOW_KEY=

# ── Bing Webmaster Tools ────────────────────────────────────────────────────
# Site verification for Bing Search Console.
# Find in Bing Webmaster Tools → Settings → Site Verification → Meta tag content value
VITE_BING_VERIFY=

# ── Google Search Console ───────────────────────────────────────────────────
# Site ownership verification.
# Find in Google Search Console → Settings → Ownership verification → HTML tag content value
VITE_GOOGLE_VERIFY=
